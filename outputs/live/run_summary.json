{
  "ok": true,
  "agent": "agent-crowding-risk-monitor",
  "output_dir": "outputs/live",
  "data_source": "Pandadata",
  "tables": {
    "lhb_list": {
      "rows": 550,
      "columns": [
        "amount",
        "change_rate",
        "date",
        "deviation",
        "reason",
        "symbol",
        "turnover",
        "type",
        "volume"
      ]
    },
    "margin": {
      "rows": 7,
      "columns": [
        "buy_on_margin_value",
        "date",
        "margin_balance",
        "margin_type",
        "short_balance",
        "symbol",
        "total_balance"
      ]
    }
  },
  "charts": [
    "charts/funding_balance_crowding.png",
    "charts/lhb_amount_top.png",
    "charts/scorecard_metrics.png"
  ],
  "report": "outputs/live/report.html"
}
